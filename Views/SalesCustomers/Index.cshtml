@model IEnumerable<SalesCustomer.Models.SalesCustomers>

@{
    ViewData["Title"] = "Index";
}
<div class="row">
    <div class="col-md-8 offset-md-2">
        <h1>Sales.Customers</h1>

        <table class="table">
            <thead>
                <tr>
                    <th>
                        @Html.DisplayNameFor(model => model.CustomerID)
                    </th>
                   
                    <th>
                        @Html.DisplayNameFor(model => model.CustomerName)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.BillToCustomerID)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.CustomerCategoryID)
                    </th>

                    <th>
                        @Html.DisplayNameFor(model => model.BuyingGroupID)
                    </th>

                    <th>
                        @Html.DisplayNameFor(model => model.PrimaryContactPersonID)
                    </th>

                         <th>
                        @Html.DisplayNameFor(model => model.AlternateContactPersonID)
                    </th>

                         <th>
                        @Html.DisplayNameFor(model => model.DeliveryMethodID)
                    </th>

                         <th>
                        @Html.DisplayNameFor(model => model.DeliveryCityID)
                    </th>


                         <th>
                        @Html.DisplayNameFor(model => model.PostalCityID)
                    </th>

                         <th>
                        @Html.DisplayNameFor(model => model.CreditLimit)
                    </th>


                         <th>
                        @Html.DisplayNameFor(model => model.AccountOpenedDate)
                    </th>


                         <th>
                        @Html.DisplayNameFor(model => model.StandardDiscountPercentage)
                    </th>

                    <th>
                        @Html.DisplayNameFor(model => model.IsStatementSent)
                    </th>



                        <th>
                        @Html.DisplayNameFor(model => model.PhoneNumber)
                    </th>

                        <th>
                        @Html.DisplayNameFor(model => model.FaxNumber)
                    </th>


                        <th>
                        @Html.DisplayNameFor(model => model.DeliveryRun)
                    </th>


                        <th>
                        @Html.DisplayNameFor(model => model.RunPosition)
                    </th>


                        <th>
                        @Html.DisplayNameFor(model => model.WebsiteURL)
                    </th>


                        <th>
                        @Html.DisplayNameFor(model => model.DeliveryAddressLine1)
                    </th>


                        <th>
                        @Html.DisplayNameFor(model => model.DeliveryAddressLine2)
                    </th>


                        <th>
                        @Html.DisplayNameFor(model => model.DeliveryPostalCode)
                    </th>


                        <th>
                        @Html.DisplayNameFor(model => model.PostalAddressLine1)
                    </th>

                    <th>
                        @Html.DisplayNameFor(model => model.PostalAddressLine2)
                    </th>


                    <th>
                        @Html.DisplayNameFor(model => model.PostalPostalCode)
                    </th>    <th>
                        @Html.DisplayNameFor(model => model.LastEditedBy)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.ValidFrom)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.ValidTo)
                    </th>

                   

                    <th>
                        <a asp-action="AddOrEdit" class="btn btn-sm btn-success">
                            <i class="fa-solid fa-plus"></i> New
                        </a>
                    </th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            @Html.DisplayFor(modelItem => item.CustomerID)
                        </td>

                        <td>
                            @Html.DisplayFor(modelItem => item.CustomerName)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.BillToCustomerID)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.BuyingGroupID)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.PrimaryContactPersonID)
                        </td>











                        <td>
                            @Html.DisplayFor(modelItem => item.AlternateContactPersonID)
                        </td>

                        <td>
                            @Html.DisplayFor(modelItem => item.DeliveryMethodID)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.DeliveryCityID)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.PostalCityID)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.CreditLimit)
                        </td>
                               <td>
                            @Html.DisplayFor(modelItem => item.AccountOpenedDate)
                        </td>

                        <td>
                            @Html.DisplayFor(modelItem => item.StandardDiscountPercentage)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.IsStatementSent)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.IsOnCreditHold)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.PaymentDays)
                        </td>
                               <td>
                            @Html.DisplayFor(modelItem => item.PhoneNumber)
                        </td>

                        <td>
                            @Html.DisplayFor(modelItem => item.FaxNumber)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.DeliveryRun)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.RunPosition)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.WebsiteURL)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.DeliveryAddressLine1)
                        </td>

                        <td>
                            @Html.DisplayFor(modelItem => item.DeliveryAddressLine2)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.DeliveryPostalCode)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.PostalAddressLine1)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.PostalAddressLine2)
                        </td>



                          <td>
                            @Html.DisplayFor(modelItem => item.PostalPostalCode)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.LastEditedBy)
                        </td>  <td>
                            @Html.DisplayFor(modelItem => item.ValidFrom)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.ValidTo)
                        </td>  





                        <td>
                            <form asp-action="Delete" asp-route-id="@item.CustomerID">
                                <div class="btn-group btn-group-sm">
                                    <a asp-action="AddOrEdit" asp-route-id="@item.CustomerID" class="btn btn-warning">
                                        <i class="fa-solid fa-pen-to-square"></i>
                                    </a>
                                    <button type="submit" class="btn btn-danger"
                                        onclick="return confirm('Are you sure to delete this record?')">
                                        <i class="far fa-trash-alt"></i>
                                    </button>
                                </div>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

